{
  "version": 2,
  "builds": [
    { "src": "server/src/index.js", "use": "@vercel/node" },
    { "src": "client/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api-docs", "destination": "/server/src/index.js" },
    { "source": "/api/v1/tasks", "destination": "/server/src/index.js" },
    { "source": "/api/v1/tasks/(.*)", "destination": "/server/src/index.js" },
    { "source": "/(.*)", "destination": "/client/$1" }
  ]
}